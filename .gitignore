# ============================================================================
# Flutter/Dart .gitignore
# ============================================================================
# This file is configured for cross-platform development:
# - Windows 11 and macOS development environments
# - Android builds on both Windows and macOS
# - iOS builds on macOS
# ============================================================================

# ============================================================================
# Operating System Files
# ============================================================================

# Windows system files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# macOS system files
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ============================================================================
# IDE and Editor Files
# ============================================================================

# IntelliJ IDEA / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code
# Note: .vscode/ folder contains launch configurations and tasks.
# Uncomment the line below if you don't want to include VS Code settings in version control.
#.vscode/

# Other editors
.atom/
.history
*.swp
*.swo
*~

# ============================================================================
# Flutter/Dart Core Files
# ============================================================================

# Flutter/Dart generated files
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
lib/generated_plugin_registrant.dart

# Flutter build outputs
/build/
/coverage/

# Flutter documentation
**/doc/api/

# ============================================================================
# Build Artifacts and Temporary Files
# ============================================================================

# General build files
*.class
*.log
*.pyc
.build/
.buildlog/
migrate_working_dir/

# 忽略json_serializable自动生成的代码
*.g.dart
# 忽略freezed自动生成的代码
*.freezed.dart

# Symbolication files (for crash analysis)
app.*.symbols

# Obfuscation maps (for code obfuscation)
app.*.map.json

# ============================================================================
# Android Platform Files
# ============================================================================

# Gradle files (build system)
**/android/.gradle
**/android/**/gradle-wrapper.jar
**/android/**/gradle-wrapper.properties
**/android/gradlew
**/android/gradlew.bat

# Android Studio / IntelliJ
**/android/captures/
**/android/**/GeneratedPluginRegistrant.java

# Local configuration files (may contain sensitive paths)
**/android/local.properties
**/android/key.properties

# Signing keys (NEVER commit these!)
*.jks
*.keystore

# Android build outputs
*.apk
*.aab
*.ap_
*.dex
**/android/app/debug
**/android/app/profile
**/android/app/release

# ============================================================================
# iOS Platform Files
# ============================================================================

# Xcode user-specific files
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/xcuserdata/

# Xcode build data
**/ios/**/DerivedData/

# CocoaPods dependencies
**/ios/**/Pods/

# Flutter iOS generated files
**/ios/Flutter/.last_build_id
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_assets/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

# iOS build outputs
*.ipa
*.app.dSYM.zip
*.app.dSYM

# Swift Package Manager
.swiftpm/

# ============================================================================
# macOS Flutter Platform Files
# ============================================================================

**/macos/Flutter/ephemeral
**/macos/Flutter/Flutter-Debug.xcconfig
**/macos/Flutter/Flutter-Release.xcconfig
**/macos/Flutter/GeneratedPluginRegistrant.swift

# ============================================================================
# Windows Flutter Platform Files
# ============================================================================

**/windows/flutter/generated_plugin_registrant.cc
**/windows/flutter/generated_plugin_registrant.h
**/windows/flutter/generated_plugins.cmake

# ============================================================================
# Version Control and Other Tools
# ============================================================================

# SVN
.svn/

# FVM (Flutter Version Management) cache
.fvm/
